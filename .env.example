# Copy to .env in the project root:  cp .env.example .env
# Never commit .env (it is in .gitignore).

# SQLAlchemy URL for Postgres. If unset, the app can build one from the
# POSTGRES_* variables below, or it falls back to a SQLite file under backend/.
# Local / Docker-style:
#   DATABASE_URL=postgresql://user:password@localhost:5432/nutrition_coach
# Or (equivalent, composed by config.py if DATABASE_URL is not set):
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=...
#   POSTGRES_DB=nutrition_coach
#   POSTGRES_HOST=localhost
#   POSTGRES_PORT=5432
#
# If Postgres is not running locally, either start the server or force SQLite:
#   USE_SQLITE=1
#
# Render / production: set DATABASE_URL to your managed Postgres internal URL
# (``postgresql://…``; ``postgres://`` is normalized automatically).

# LLM
GROQ_API_KEY=
# OPENAI_API_KEY=
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SECRET_KEY=change-me-in-production
