# Copy to .env in the project root:  cp .env.example .env
# Never commit .env (it is in .gitignore).

# SQLAlchemy URL — required for production Postgres. If unset, the app uses a
# default SQLite file under backend/ (see config.py).
# Local Postgres example (replace user, password, host, dbname):
# DATABASE_URL=postgresql://user:password@localhost:5432/nutrition_coach
#
# Render / production: set DATABASE_URL to your managed Postgres (e.g. from Render’s dashboard).

# LLM
GROQ_API_KEY=
# OPENAI_API_KEY=
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SECRET_KEY=change-me-in-production
