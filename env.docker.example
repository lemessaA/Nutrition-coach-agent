# Copy to `.env` next to `docker-compose.yml` before `docker compose up`.
# Values here are merged with docker-compose.yml (secrets you add are not committed).

# Required for LLM features
GROQ_API_KEY=
# OPENAI_API_KEY=

LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Browsers allowed to call the API (comma-separated). Add your deployed front-end URL.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: override if you change db service credentials in docker-compose.yml
# DATABASE_URL is set inside docker-compose for the `api` service to point at `db`.

SECRET_KEY=change-me-in-production
