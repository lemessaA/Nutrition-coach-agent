# Copy to `.env` next to `docker-compose.yml`:  cp env.docker.example .env
# Edit secrets locally — never commit `.env`.

# --- PostgreSQL (used by the `db` service and to build the API `DATABASE_URL`) ---
POSTGRES_USER=postgres
# Required for `docker compose` (the compose file will error if this is empty):
POSTGRES_PASSWORD=
POSTGRES_DB=nutrition_coach

# --- API ---
# Required for LLM features
GROQ_API_KEY=
# OPENAI_API_KEY=

LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Browsers allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SECRET_KEY=change-me-in-production
